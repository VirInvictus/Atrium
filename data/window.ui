<?xml version="1.0" encoding="UTF-8"?>
<interface domain="atrium">
  <requires lib="gtk" version="4.16"/>

  <template class="AtriumWindow" parent="GtkApplicationWindow">
    <property name="title">Atrium</property>
    <property name="default-width">1100</property>
    <property name="default-height">700</property>

    <!-- Phase 22 C8 — tiling-first posture (spec §3.7). An invisible
         titlebar suppresses GTK's default header; the window controls
         are hidden everywhere (the compositor owns close / maximize /
         minimize, Ctrl+Q quits), so each GtkHeaderBar sets
         show-title-buttons=false and keeps only its functional
         controls. Was an AdwApplicationWindow with adwaita-managed
         chrome. -->
    <child type="titlebar">
      <object class="GtkHeaderBar">
        <property name="visible">false</property>
      </object>
    </child>

    <property name="child">
      <object class="GtkBox">
        <!-- Phase 22 C8 — was AdwToolbarView. A vertical stack of the
             top headerbar + the content paned. v0.7.1 — the class
             scopes the headerbar-flattening CSS rule
             (.atrium-main-toolbar headerbar { background: transparent;
             … }) to just this window. -->
        <property name="orientation">vertical</property>
        <style>
          <class name="atrium-main-toolbar"/>
        </style>
        <child>
          <object class="GtkHeaderBar">
            <property name="show-title-buttons">false</property>
            <child type="end">
              <object class="GtkMenuButton" id="menu_button">
                <property name="primary">true</property>
                <property name="icon-name">open-menu-symbolic</property>
                <property name="tooltip-text" translatable="yes">Main Menu</property>
              </object>
            </child>
          </object>
        </child>

        <child>
          <object class="GtkPaned" id="overlay_split">
            <!-- Phase 22 C6 — was AdwOverlaySplitView. The inspector pane is
                 the end (right) child; AtriumWindow::apply_mode shows it only
                 in Builder Mode by toggling inspector_pane_host's visibility.
                 The adaptive narrow-collapse (adwaita's overlay behaviour) is
                 deferred to the Phase 21 geometry audit. -->
            <property name="orientation">horizontal</property>
            <property name="vexpand">true</property>
            <property name="position">760</property>
            <property name="resize-end-child">false</property>
            <property name="shrink-end-child">false</property>

            <property name="end-child">
              <object class="GtkBox" id="inspector_pane_host">
                <property name="visible">false</property>
                <!-- Populated by inspector_pane::install at startup; the
                     content swaps between an empty placeholder (no task
                     selected) and a per-task editor (task selected). -->
              </object>
            </property>

            <property name="start-child">
          <object class="GtkPaned" id="split_view">
            <!-- Phase 22 C6 — was AdwNavigationSplitView (Lists | content). -->
            <property name="orientation">horizontal</property>
            <property name="position">260</property>
            <property name="resize-start-child">false</property>
            <property name="shrink-start-child">false</property>

            <property name="start-child">
                  <object class="GtkBox">
                    <!-- Phase 22 C8 — was AdwToolbarView. v0.7.1 — the
                         class scopes the sidebar's flat atmospheric tint
                         (.atrium-sidebar-pane in data/style.css) to the
                         whole surface so the headerbar, filter entry, and
                         listbox all share one continuous tone. -->
                    <property name="orientation">vertical</property>
                    <style>
                      <class name="atrium-sidebar-pane"/>
                    </style>
                    <child>
                      <object class="GtkHeaderBar">
                        <property name="show-title-buttons">false</property>
                        <!-- v0.7.2 — the empty title-widget keeps this
                             header as pure chrome; the filter entry below
                             acts as the sidebar's visual top. Was an empty
                             AdwWindowTitle. -->
                        <property name="title-widget">
                          <object class="GtkLabel"/>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="vexpand">true</property>
                        <child>
                          <object class="GtkSearchEntry" id="sidebar_filter">
                            <property name="placeholder-text" translatable="yes">Filter lists…</property>
                            <property name="margin-start">8</property>
                            <property name="margin-end">8</property>
                            <property name="margin-top">4</property>
                            <property name="margin-bottom">4</property>
                            <property name="search-delay">100</property>
                            <!-- v0.7.5 — same ghost treatment as the
                                 quick-add at the bottom of the list:
                                 dim by default, full opacity on hover
                                 / focus-within. CSS class lives in
                                 data/style.css. -->
                            <style>
                              <class name="atrium-filter-ghost"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkScrolledWindow">
                            <property name="hscrollbar-policy">never</property>
                            <property name="vexpand">true</property>
                            <property name="child">
                              <object class="GtkListBox" id="sidebar_list">
                                <property name="selection-mode">single</property>
                                <style>
                                  <class name="navigation-sidebar"/>
                                </style>
                              </object>
                            </property>
                          </object>
                        </child>
                        <!-- v0.2.2 — empty-library hint. Visible only
                             when there are no areas, projects, or tags
                             yet. AtriumWindow::refresh_sidebar_empty_hint
                             toggles the revealer and the "create first
                             project" action lives on win.new-project. -->
                        <child>
                          <object class="GtkRevealer" id="sidebar_empty_hint">
                            <property name="reveal-child">false</property>
                            <property name="transition-type">slide-up</property>
                            <property name="child">
                              <object class="GtkBox">
                                <property name="orientation">vertical</property>
                                <property name="spacing">8</property>
                                <property name="margin-start">12</property>
                                <property name="margin-end">12</property>
                                <property name="margin-top">12</property>
                                <property name="margin-bottom">16</property>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">No projects yet</property>
                                    <property name="xalign">0</property>
                                    <style>
                                      <class name="caption-heading"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkLabel">
                                    <property name="label" translatable="yes">Group tasks by what they're for. You can always add an area later to organise multiple projects.</property>
                                    <property name="wrap">true</property>
                                    <property name="xalign">0</property>
                                    <property name="max-width-chars">28</property>
                                    <style>
                                      <class name="caption"/>
                                      <class name="dim-label"/>
                                    </style>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton">
                                    <property name="label" translatable="yes">New Project</property>
                                    <property name="action-name">app.new-project</property>
                                    <property name="halign">start</property>
                                    <style>
                                      <class name="suggested-action"/>
                                      <class name="pill"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
            </property>

            <property name="end-child">
                  <object class="GtkBox">
                    <!-- Phase 22 C8 — was AdwToolbarView. -->
                    <property name="orientation">vertical</property>
                    <child>
                      <object class="GtkHeaderBar">
                        <property name="show-title-buttons">false</property>
                        <!-- v0.7.0 — the empty title widget keeps this
                             header as pure chrome (new-task + search); the
                             magazine-spread page title lives in the strip
                             below (page_title_strip). Was an empty
                             AdwWindowTitle. -->
                        <property name="title-widget">
                          <object class="GtkLabel"/>
                        </property>
                        <child type="start">
                          <object class="GtkButton" id="new_task_button">
                            <property name="icon-name">list-add-symbolic</property>
                            <property name="tooltip-text" translatable="yes">New Task (Ctrl+N)</property>
                            <property name="action-name">app.new-task</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>
                        <child type="end">
                          <object class="GtkToggleButton" id="search_button">
                            <property name="icon-name">system-search-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Search (Ctrl+F)</property>
                            <style>
                              <class name="flat"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <!-- v0.7.0 — magazine-spread page title strip.
                           Lives between the header-bar chrome and the
                           content stack so every page inherits one
                           shared title surface. The big title and
                           the subtitle are bound in window.rs's
                           set_active_list; the subtitle is hidden
                           via set_visible(false) when there's no
                           supporting line for the active view. -->
                      <object class="GtkBox" id="page_title_strip">
                        <property name="orientation">vertical</property>
                        <property name="margin-start">24</property>
                        <property name="margin-end">24</property>
                        <property name="margin-top">14</property>
                        <property name="margin-bottom">10</property>
                        <property name="spacing">2</property>
                        <style>
                          <class name="atrium-page-title-strip"/>
                        </style>
                        <child>
                          <object class="GtkLabel" id="page_title_label">
                            <property name="label">Today</property>
                            <property name="halign">start</property>
                            <property name="xalign">0</property>
                            <style>
                              <class name="atrium-page-title"/>
                            </style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel" id="page_subtitle_label">
                            <property name="label"></property>
                            <property name="halign">start</property>
                            <property name="xalign">0</property>
                            <property name="visible">false</property>
                            <style>
                              <class name="atrium-page-subtitle"/>
                              <class name="dim-label"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <object class="GtkSearchBar" id="search_bar">
                        <property name="search-mode-enabled">false</property>
                        <property name="key-capture-widget">task_list_view</property>
                        <child>
                          <!-- v0.4.1 — search bar grew a `?` help button next
                               to the entry. The MenuButton's popover is
                               populated in code (see window.rs::wire_search_bar)
                               with a structured operator reference. Wrapping
                               in a horizontal Box keeps the entry growing to
                               fill while the button hugs the right edge. -->
                          <object class="GtkBox">
                            <property name="orientation">horizontal</property>
                            <property name="spacing">6</property>
                            <child>
                              <object class="GtkSearchEntry" id="search_entry">
                                <property name="placeholder-text" translatable="yes">Find tasks — try tag:errand, due:today, or is:overdue</property>
                                <property name="hexpand">true</property>
                                <property name="search-delay">200</property>
                              </object>
                            </child>
                            <child>
                              <object class="GtkMenuButton" id="search_help_button">
                                <property name="icon-name">help-about-symbolic</property>
                                <property name="tooltip-text" translatable="yes">Search operator reference</property>
                                <style>
                                  <class name="flat"/>
                                </style>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                    <child>
                      <!-- Owned toast host (Phase 22 C3): a GtkOverlay over the
                           content stack with a crossfading auto-hide revealer as
                           its overlay child, replacing AdwToastOverlay. show_toast /
                           show_undo_toast in search.rs drive toast_revealer. -->
                      <object class="GtkOverlay" id="content_overlay">
                        <property name="vexpand">true</property>
                        <property name="child">
                          <object class="GtkStack" id="content_stack">
                            <property name="transition-type">crossfade</property>

                            <child>
                              <object class="GtkStackPage">
                                <property name="name">empty</property>
                                <property name="child">
                                  <!-- Host for the owned empty-state page (Phase 22 C2).
                                       The window builds a crate::ui::status_page::StatusPage
                                       in code and appends it here; update_empty_state swaps
                                       its title / description / icon per active list. -->
                                  <object class="GtkBox" id="content_status_host">
                                    <property name="orientation">vertical</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- Phase 12 — Forecast view container. The window
                                   builds the actual forecast widget in code via
                                   `forecast::build_page` and parents it here as
                                   the bin's child every time the active list
                                   becomes ActiveList::Forecast. -->
                              <object class="GtkStackPage">
                                <property name="name">forecast</property>
                                <property name="child">
                                  <object class="GtkBox" id="forecast_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- Phase 13 — Review queue container. Same shape
                                   as the forecast page; window builds the page
                                   widget via `review::build_page` and mounts
                                   it here when ActiveList::Review activates. -->
                              <object class="GtkStackPage">
                                <property name="name">review</property>
                                <property name="child">
                                  <object class="GtkBox" id="review_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- v0.6.0 (Slice C2) — Logbook day-band view.
                                   Same pattern as forecast/review: window
                                   builds the page via logbook::build_page and
                                   mounts it here when ActiveList::Logbook
                                   activates. Replaces the flat list rendering
                                   that the regular `list` page used to do for
                                   Logbook. -->
                              <object class="GtkStackPage">
                                <property name="name">logbook</property>
                                <property name="child">
                                  <object class="GtkBox" id="logbook_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- v0.6.0 (Slice D1 GUI) — kanban board page.
                                   Same pattern as the other custom pages —
                                   the window builds the widget via
                                   board::build_page and mounts it here when
                                   the active Perspective has renderer=board.
                                   Read-only in v0.6.0; row interactivity and
                                   drag-drop follow in a sibling patch. -->
                              <object class="GtkStackPage">
                                <property name="name">board</property>
                                <property name="child">
                                  <object class="GtkBox" id="board_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- v0.6.4 (Slice D2) — Agenda canonical page.
                                   Org-mode-style chronological view rendering
                                   Overdue / Today / Tomorrow / This Week /
                                   Next Week sections. Window builds the
                                   widget via agenda::build_page and mounts
                                   it here when ActiveList::Agenda is
                                   selected. -->
                              <object class="GtkStackPage">
                                <property name="name">agenda</property>
                                <property name="child">
                                  <object class="GtkBox" id="agenda_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <!-- Phase 12.5 (v0.11.0) — Calendar Month View.
                                   Builder-only paper-calendar lens. Window
                                   builds the widget via calendar::build_page
                                   and mounts it here when ActiveList::Calendar
                                   is selected. -->
                              <object class="GtkStackPage">
                                <property name="name">calendar</property>
                                <property name="child">
                                  <object class="GtkBox" id="calendar_host">
                                    <property name="hexpand">true</property>
                                    <property name="vexpand">true</property>
                                  </object>
                                </property>
                              </object>
                            </child>

                            <child>
                              <object class="GtkStackPage">
                                <property name="name">list</property>
                                <property name="child">
                                  <object class="GtkBox">
                                    <property name="orientation">vertical</property>
                                    <child>
                                      <object class="GtkRevealer" id="selection_revealer">
                                        <property name="reveal-child">false</property>
                                        <property name="transition-type">slide-down</property>
                                        <property name="child">
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <property name="spacing">8</property>
                                            <property name="margin-start">12</property>
                                            <property name="margin-end">12</property>
                                            <property name="margin-top">8</property>
                                            <property name="margin-bottom">8</property>
                                            <style>
                                              <class name="toolbar"/>
                                            </style>
                                            <child>
                                              <object class="GtkLabel" id="selection_label">
                                                <property name="label">0 selected</property>
                                                <property name="hexpand">true</property>
                                                <property name="halign">start</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Move…</property>
                                                <property name="action-name">win.bulk-move</property>
                                                <property name="tooltip-text" translatable="yes">Move the selected tasks to a project</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Tag…</property>
                                                <property name="action-name">win.bulk-tag</property>
                                                <property name="tooltip-text" translatable="yes">Add or remove a tag across the selected tasks</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkMenuButton" id="bulk_schedule_button">
                                                <property name="label" translatable="yes">Schedule</property>
                                                <property name="tooltip-text" translatable="yes">Reschedule the selected tasks</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Complete</property>
                                                <property name="action-name">win.bulk-complete</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="label" translatable="yes">Delete</property>
                                                <property name="action-name">win.bulk-delete</property>
                                                <style>
                                                  <class name="destructive-action"/>
                                                </style>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkButton">
                                                <property name="icon-name">window-close-symbolic</property>
                                                <property name="action-name">win.bulk-clear</property>
                                                <property name="tooltip-text" translatable="yes">Clear selection (Esc)</property>
                                                <style>
                                                  <class name="flat"/>
                                                </style>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <!-- Phase 10 — Builder Mode project page extras.
                                           Visible only when ActiveList::Project(id) is
                                           active AND the GSettings mode = "builder".
                                           Holds Sequential + Review interval pickers
                                           wired to worker.update_project. -->
                                      <object class="GtkRevealer" id="project_extras_revealer">
                                        <property name="reveal-child">false</property>
                                        <property name="transition-type">slide-down</property>
                                        <property name="child">
                                          <object class="GtkBox">
                                            <property name="orientation">horizontal</property>
                                            <property name="spacing">16</property>
                                            <property name="margin-start">12</property>
                                            <property name="margin-end">12</property>
                                            <property name="margin-top">8</property>
                                            <property name="margin-bottom">8</property>
                                            <style>
                                              <class name="toolbar"/>
                                            </style>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="label" translatable="yes">Sequential</property>
                                                <property name="tooltip-text" translatable="yes">In a sequential project only the first incomplete task is "available". Phase 11 lands the rendering consequence.</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkSwitch" id="project_sequential_switch">
                                                <property name="valign">center</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkSeparator">
                                                <property name="orientation">vertical</property>
                                                <property name="margin-start">8</property>
                                                <property name="margin-end">8</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="label" translatable="yes">Review every</property>
                                                <property name="tooltip-text" translatable="yes">Days between Review queue surfacing. 0 means the project never auto-surfaces. Phase 13 lands the Review queue itself.</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkSpinButton" id="project_review_spin">
                                                <property name="adjustment">
                                                  <object class="GtkAdjustment">
                                                    <property name="lower">0</property>
                                                    <property name="upper">365</property>
                                                    <property name="step-increment">1</property>
                                                    <property name="page-increment">7</property>
                                                  </object>
                                                </property>
                                                <property name="numeric">true</property>
                                                <property name="valign">center</property>
                                              </object>
                                            </child>
                                            <child>
                                              <object class="GtkLabel">
                                                <property name="label" translatable="yes">days</property>
                                                <property name="hexpand">true</property>
                                                <property name="halign">start</property>
                                              </object>
                                            </child>
                                          </object>
                                        </property>
                                      </object>
                                    </child>
                                    <child>
                                      <!-- v0.5.0 (Slice B1) capped the list width so the
                                           rows don't stretch into runway on wide windows —
                                           Things-3-style paper-list calm. Phase 22 C8
                                           dropped the AdwClamp; the owned AtriumClamp
                                           (max 960) reinstates it as part of the
                                           tiling-forward layout work. It wraps the
                                           ScrolledWindow so the ListView keeps native
                                           scrolling + row virtualisation. -->
                                      <object class="AtriumClamp">
                                        <property name="vexpand">true</property>
                                        <child>
                                          <object class="GtkScrolledWindow">
                                            <property name="hscrollbar-policy">never</property>
                                            <property name="vexpand">true</property>
                                            <property name="child">
                                              <object class="GtkListView" id="task_list_view">
                                                <property name="show-separators">true</property>
                                                <property name="single-click-activate">false</property>
                                                <property name="margin-top">12</property>
                                                <style>
                                                  <class name="atrium-task-listview"/>
                                                </style>
                                              </object>
                                            </property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">horizontal</property>
                                        <property name="margin-start">12</property>
                                        <property name="margin-end">12</property>
                                        <property name="margin-top">8</property>
                                        <property name="margin-bottom">8</property>
                                        <property name="spacing">8</property>
                                        <style>
                                          <class name="atrium-quick-add"/>
                                        </style>
                                        <child>
                                          <object class="GtkImage">
                                            <property name="icon-name">list-add-symbolic</property>
                                          </object>
                                        </child>
                                        <child>
                                          <object class="GtkEntry" id="new_task_entry">
                                            <property name="placeholder-text" translatable="yes">Add task…</property>
                                            <property name="hexpand">true</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </property>
                        <child type="overlay">
                          <object class="GtkRevealer" id="toast_revealer">
                            <property name="transition-type">crossfade</property>
                            <property name="halign">center</property>
                            <property name="valign">end</property>
                            <property name="reveal-child">false</property>
                            <property name="margin-bottom">24</property>
                            <property name="child">
                              <object class="GtkBox" id="toast_box">
                                <property name="halign">center</property>
                                <property name="spacing">12</property>
                                <style>
                                  <class name="toast"/>
                                </style>
                                <child>
                                  <object class="GtkLabel" id="toast_label">
                                    <property name="wrap">true</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkButton" id="toast_button">
                                    <property name="visible">false</property>
                                    <style>
                                      <class name="flat"/>
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
            </property>
          </object>
        </property>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
