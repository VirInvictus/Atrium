SUMMARY:Not a todo — should drop
DTSTART:20260601T000000Z
END:VEVENT
BEGIN:VJOURNAL
UID:journal-not-task@example.com
DTSTAMP:20260528T120000Z
SUMMARY:Also not a todo
END:VJOURNAL
BEGIN:VTODO
UID:lossy-task-1@example.com
DTSTAMP:20260528T120000Z
SUMMARY:Has alarm + attendee + geo + tz
DTSTART;TZID=America/New_York:20260601T100000
DUE;TZID=America/New_York:20260605T170000
STATUS:NEEDS-ACTION
GEO:40.7128;-74.0060
ATTENDEE:mailto:a@example.com
ATTENDEE:mailto:b@example.com
PERCENT-COMPLETE:40
DURATION:PT2H
RESOURCES:Projector,Whiteboard
URL:https://example.com/x
X-CUSTOM-FIELD:should round-trip
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:Reminder
TRIGGER:-PT30M
END:VALARM
BEGIN:VALARM
ACTION:AUDIO
TRIGGER:-PT15M
END:VALARM
END:VTODO
